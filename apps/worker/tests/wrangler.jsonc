{
  "name": "sharehtml-test",
  "main": "../src/index.ts",
  "compatibility_date": "2025-04-01",
  "vars": {},
  // Assets are handled by the Vite plugin in dev/build.
  // For tests, we stub the ASSETS binding via vitest config.
  "r2_buckets": [
    {
      "binding": "DOCUMENTS_BUCKET",
      "bucket_name": "sharehtml-documents",
    },
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "DOCUMENT_DO",
        "class_name": "DocumentDO",
      },
      {
        "name": "REGISTRY_DO",
        "class_name": "RegistryDO",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["DocumentDO", "RegistryDO"],
    },
  ],
}
